# --- Acurast deployer credentials (the SDK reads NONE of these from env itself;
#     this service loads them and passes them explicitly) ---

# Mnemonic of the deployer account. Must hold cACU (canary) to pay for deployments.
# NEVER commit the real value. NEVER logged, never written to history.jsonl.
ACURAST_MNEMONIC="word word word ... word"

# Substrate RPC websocket endpoint (canary by default).
RPC_WSS="wss://canarynet-ws-1.acurast-h-server-2.papers.tech"

# IPFS upload endpoint + API key (deployment code is bundled and uploaded here).
IPFS_ENDPOINT="https://your-ipfs-endpoint"
IPFS_API_KEY="your-ipfs-api-key"

# --- Service config ---

# Public base URL of THIS api, used to mint the per-deployment CALLBACK_URL that
# the workload POSTs back to. Must be reachable from the Acurast processor.
API_BASE_URL="https://qvac-api.acurast.dev"

# Comma-separated full-access API keys. Each can deploy any template + read history.
API_KEYS="changeme-key-1,changeme-key-2"

# Restricted key baked into the public landing page. Can ONLY deploy template "qvac",
# rate-limited per IP. Safe to expose in the static site.
PUBLIC_DEPLOY_KEY="changeme-public-qvac-key"

# Tunnel domain suffix. Optional: defaults to the shared, Acurast-managed zone
# tunnel.acurast.dev (wildcard A + _acu TXT already published, no DNS work needed).
# Only set this to a custom vanity domain you control (then publish your own records).
# DOMAIN_SUFFIX="tunnel.acurast.dev"

# HTTP port and data directory.
PORT="8080"
DATA_DIR="./data"

# Allowed CORS origins (the landing page is on a different origin than the API).
# Comma-separated, or "*" for any. API is key-protected so "*" is acceptable.
CORS_ORIGINS="*"

# Set true to simulate deployments locally (no chain/IPFS/funds). Leave unset in prod.
# MOCK_DEPLOY="true"

# Max public-key deploys per IP per hour (rate limit).
PUBLIC_DEPLOY_RATE_PER_HOUR="5"

# --- Traefik routing (your existing Traefik handles TLS + routing) ---

# Hostnames Traefik routes to the two containers.
API_HOST="qvac-api.acurast.dev"
WEB_HOST="qvac.acurast.dev"

# The external docker network Traefik is attached to.
TRAEFIK_NETWORK="proxy"
# Traefik https entrypoint (match your Traefik config).
TRAEFIK_ENTRYPOINT="websecure"
# TLS uses Traefik's file-provider certs (tls=true), NOT ACME — add an
# acurast.dev cert to your Traefik certs.yml. No certresolver needed.
