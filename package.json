{
  "name": "acurast-deployer-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted service that deploys curated workloads to Acurast and tracks tunnel registration",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@acurast/sdk": "1.2.2",
    "@polkadot/api": "^16.1.2",
    "@polkadot/keyring": "^13.5.1",
    "@polkadot/util-crypto": "^13.5.1",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
