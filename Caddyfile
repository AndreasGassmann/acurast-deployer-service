# Landing page (static Astro build served from /srv).
qvac.acurast.dev {
	encode gzip zstd
	root * /srv
	try_files {path} /index.html
	file_server
}

# Backend API (reverse proxy to the node service).
api.qvac.acurast.dev {
	encode gzip zstd
	reverse_proxy api:8080 {
		# SSE: disable buffering so progress events flush immediately.
		flush_interval -1
	}
}
